;Project Name: 001
;Project ID: NO PROJECT DESCRIPTION
$PROBLEM    PK_Warfarin.R
$INPUT      C ID TIME DV ADDL II AMT CMT SEX AGE HEG WEG CYP
$DATA      warfarinRCO.csv IGNORE=C
$SUBROUTINE ADVAN2 TRANS2
$PK
CL=THETA(1)*EXP(ETA(1))
V=THETA(2)*EXP(ETA(2))
KA=THETA(3)
S2=V

$ERROR
DEL=0
IF (F.LE.0.0001) DEL=1
IPRED=F
W1= F
W2= 1
IRES= DV-IPRED
IWRES=IRES/(W1+W2)
Y = F + W1*ERR(1) + W2*ERR(2)

$THETA  (0,0.16) ; [CL]
 (4,8) ; [V]
 0.36 FIX ; [KA]
$OMEGA  0.2  ; [CL] omega(1,1)
 0.2  ; [V] omega(2,2)
$SIGMA  0.2  ; [A] sigma(2,2)
 0.2  ; [A] sigma(2,2)_
$ESTIMATION METHOD=1 INTE PRINT=5 MAX=9999 SIG=3 POSTHOC MSFO=005.MSF
; Xpose
$COVARIANCE
$TABLE      ID TIME DV AMT ADDL II CMT EVID MDV IPRED PRED IWRES CWRES
            ONEHEADER NOPRINT FILE=sdtab1
$TABLE      ID CL V KA ETA1 ETA2 ONEHEADER NOPRINT FILE=patab1
$TABLE      ID AGE WEG HEG NOPRINT NOAPPEND ONEHEADER FILE=cotab1
$TABLE      ID CYP NOPRINT ONEHEADER FILE=catab1


NM-TRAN MESSAGES
  
 WARNINGS AND ERRORS (IF ANY) FOR PROBLEM    1
             
 (WARNING  2) NM-TRAN INFERS THAT THE DATA ARE POPULATION.
  
Note: Analytical 2nd Derivatives are constructed in FSUBS but are never used.
      You may insert $ABBR DERIV2=NO after the first $PROB to save FSUBS construction and compilation time
  

